{
  "cleanupPeriodDays": 14,
  "attribution": {
    "commit": ""
  },
  "permissions": {
    "allow": [
      "Bash(awk *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(docker exec *)",
      "Bash(docker stop *)",
      "Bash(docker rm *)",
      "Bash(find *)",
      "Bash(gh *)",
      "Bash(git *)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(ls *)",
      "Bash(mdformat *)",
      "Bash(mkdir *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(ruff *)",
      "Bash(sed *)",
      "Bash(sort *)",
      "Bash(tar *)",
      "Bash(tox *)",
      "Bash(tree *)",
      "Bash(uniq *)",
      "Bash(unzip *)",
      "Bash(wc *)",
      "Bash(which *)",
      "Bash(xargs *)",
      "Bash(yq *)",
      "Bash(brew *)",
      "Bash(chezmoi *)",
      "Bash(chmod *)",
      "Bash(fish_indent *)",
      "Bash(pre-commit *)",
      "Bash(prek *)",
      "Bash(curl *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(cat *)",
      "Bash(.tox/*/bin/python -m pytest *)",
      "Bash(.tox/*/bin/python -m pytest)",
      "Bash(command -v *)",
      "Bash(dig:*)",
      "Bash(scutil --get *)",
      "Bash(bun --version)",
      "Bash(npm --version)",
      "Bash(ccstatusline --version)",
      "Bash(python3 -m json.tool)",
      "Bash(uv run {{ .chezmoi.homeDir }}/.claude/skills/no-slop/scripts/slop_score.py*)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "Skill(claude-in-chrome)",
      "WebSearch"
    ],
    "defaultMode": "acceptEdits"
  },
  "model": {{ output "sh" "-c" `jq -r '.model // "opus[1m]"' "$HOME/.claude/settings.json" 2>/dev/null || echo 'opus[1m]'` | trim | quote }},
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh SessionStart '✨'"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh SessionEnd '👋'"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh UserPromptSubmit '🏃'"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "ccstatusline --hook"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh PermissionRequest '❓' permission.aiff"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh PreToolUse '🏃'"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "ccstatusline --hook"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh Notification '❗' waiting.aiff"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/notify.sh Stop '💤' complete.aiff"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "ccstatusline"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipWorkflowUsageWarning": true
}
