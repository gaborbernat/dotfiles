command = /opt/homebrew/bin/fish

theme = Monokai Remastered
font-family = JetBrainsMono Nerd Font
font-family = Symbols Nerd Font Mono
font-size = 12
font-feature = calt
font-feature = clig
font-feature = liga
window-padding-x = 4
window-padding-y = 4
window-padding-color = extend
macos-titlebar-style = tabs

cursor-style = bar
cursor-style-blink = true

scrollback-limit = 100000000
mouse-hide-while-typing = true
focus-follows-mouse = true
copy-on-select = clipboard
clipboard-paste-protection = false
split-divider-color = #998A00
split-preserve-zoom = navigation

window-save-state = always

notify-on-command-finish = unfocused
notify-on-command-finish-action = notify
scroll-to-bottom = keystroke,output
selection-word-chars = \t\n{}[]()\"'`,;:@
macos-applescript = false

keybind = global:super+grave_accent=toggle_quick_terminal
keybind = shift+enter=text:\x1b\r
keybind = super+h=new_split:right
keybind = super+j=new_split:down
keybind = super+d=close_surface
keybind = super+w=close_surface
keybind = super+left=goto_split:left
keybind = super+right=goto_split:right
keybind = super+up=goto_split:up
keybind = super+down=goto_split:down
keybind = super+shift+f=toggle_split_zoom
keybind = super+page_up=previous_tab
keybind = super+page_down=next_tab
keybind = shift+page_up=scroll_page_up
keybind = shift+page_down=scroll_page_down
keybind = shift+up=scroll_page_lines:-1
keybind = shift+down=scroll_page_lines:1
keybind = ctrl+shift+up=jump_to_prompt:-1
keybind = ctrl+shift+down=jump_to_prompt:1
keybind = super+shift+o=toggle_background_opacity
