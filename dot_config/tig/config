set split-view-width = 75%
bind generic	<PgDown>	move-half-page-down
bind generic	<Space>	move-half-page-up
bind generic	<C-U> move-page-up
bind generic	<C-D> move-page-down
set wrap-lines		= yes
set tab-size		= 2
set commit-order = default
set ignore-case = smart-case
set refresh-mode = auto
set main-view-date = relative
bind generic Y @sh -c "printf '%s' %(commit) | pbcopy"
