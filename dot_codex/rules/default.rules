# Codex execpolicy allowlist — parity with Claude Code's permissions.allow Bash(...) rules.
# Allow-listed commands auto-run under approval_policy = "on-request"; everything else prompts.
# prefix_rule matches an ordered argv prefix (NOT a glob), so pattern=["git"] == Bash(git *).
# Note: execpolicy is a Codex preview feature; an "allow" decision also bypasses the sandbox.

prefix_rule(pattern = ["awk"], decision = "allow")
prefix_rule(pattern = ["brew"], decision = "allow")
prefix_rule(pattern = ["cat"], decision = "allow")
prefix_rule(pattern = ["chezmoi"], decision = "allow")
prefix_rule(pattern = ["chmod"], decision = "allow")
prefix_rule(pattern = ["codex"], decision = "allow")
prefix_rule(pattern = ["curl"], decision = "allow")
prefix_rule(pattern = ["docker"], decision = "allow")
prefix_rule(pattern = ["find"], decision = "allow")
prefix_rule(pattern = ["fish_indent"], decision = "allow")
prefix_rule(pattern = ["gh"], decision = "allow")
prefix_rule(pattern = ["git"], decision = "allow")
prefix_rule(pattern = ["grep"], decision = "allow")
prefix_rule(pattern = ["head"], decision = "allow")
prefix_rule(pattern = ["jq"], decision = "allow")
prefix_rule(pattern = ["ls"], decision = "allow")
prefix_rule(pattern = ["mdformat"], decision = "allow")
prefix_rule(pattern = ["mkdir"], decision = "allow")
prefix_rule(pattern = ["mv"], decision = "allow")
prefix_rule(pattern = ["npm"], decision = "allow")
prefix_rule(pattern = ["pre-commit"], decision = "allow")
prefix_rule(pattern = ["prek"], decision = "allow")
prefix_rule(pattern = ["rm"], decision = "allow")
prefix_rule(pattern = ["ruff"], decision = "allow")
prefix_rule(pattern = ["sed"], decision = "allow")
prefix_rule(pattern = ["sort"], decision = "allow")
prefix_rule(pattern = ["tail"], decision = "allow")
prefix_rule(pattern = ["tar"], decision = "allow")
prefix_rule(pattern = ["tox"], decision = "allow")
prefix_rule(pattern = ["tree"], decision = "allow")
prefix_rule(pattern = ["uniq"], decision = "allow")
prefix_rule(pattern = ["unzip"], decision = "allow")
prefix_rule(pattern = ["wc"], decision = "allow")
prefix_rule(pattern = ["which"], decision = "allow")
prefix_rule(pattern = ["xargs"], decision = "allow")
prefix_rule(pattern = ["yq"], decision = "allow")
prefix_rule(pattern = ["python", "-m", "pytest"], decision = "allow")
