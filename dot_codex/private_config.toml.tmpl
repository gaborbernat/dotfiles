{{- $work := joinPath .chezmoi.homeDir ".local/share/chezmoi-private/codex_work.toml" -}}
model_reasoning_effort = "xhigh"
suppress_unstable_features_warning = true

# ─── Developer Instructions ──────────────────────────────────────────────────
developer_instructions = """
# Communication Style
- Be concise and direct in responses, professional but avoid corporate jargon and platitudes.
- Don't repeat yourself.
- Use code examples when explaining concepts.
- Avoid emojis unless specifically requested or files alongside it has them.
- This applies in documentation, comments, commit messages, and any user-facing text.

# Code Quality Standards
- Follow established project conventions and style by always checking first files alongside the one to edit.
- Avoid writing comments; code should be self-documenting. Only include comments that explain why, not how.
- Prefer explicit over implicit code.
- Include error handling in production code, but don't use blank exceptions—be explicit about what errors can happen.
- Never add todos.
- Only create variables if that value is re-used.

# Performance & Efficiency
- Prefer bulk operations over loops when possible.
- Use appropriate data structures (sets for membership, dicts for lookups).
- Consider memory usage for large datasets.

# Python Code Standards
- Before generating code, read pyproject.toml and use latest supported features.
- Always use the walrus operator where possible.
- Order methods in topological usage order from top to bottom like reading a book, including main entrypoint.
- Run `ruff format .; ruff check . --fix --unsafe-fixes . --output-format=concise` after editing Python files and ensure it passes.
- Use pytest-mock instead of importing from unittest; prefer creating multiple files rather than classes to group tests.
- All code, including tests, must be fully type annotated.
- Use MagicMock for mock objects rather than defining custom mock classes.
- When tox.toml or tox.ini exists at project root, use .tox/dev/bin/python as the interpreter (create via `tox run` if needed).
- Format markdown with `mdformat --wrap 120` after every edit.
- Align code at 120 characters.

# Testing Philosophy
- Write tests that verify behavior, not implementation.
- Test edge cases and error conditions.
- Prefer integration tests over excessive unit test mocking.
- Achieve 100% coverage on all code, including tests.
- One test should test one thing; prefer multiple separate tests.

# Tool Preferences
- For Python projects: use ruff for format/linting and ty for type checking.
- Align at 120 characters.

# Development Approach
- Start by understanding the existing codebase and strive to follow existing patterns.
- Break down complex tasks into smaller, manageable steps.
- Document significant decisions and architectural choices.
- Never live run scripts unless explicitly asked and confirmed it's safe.

# Security Considerations
- Use environment variables for configuration secrets.

# Git Commits
- Subject: ≤ 50 chars, imperative mood, no period.
- Small changes: one-line commit.
- Complex changes: add body (wrap at 80 chars) explaining what/why; reference issues.
- Keep commits atomic and self-explanatory; split by concern.
"""

# Bloomberg Codex CLI — user config template
# Location: ~/.codex/config.toml
# Model, provider, and security settings are managed via /etc/codex/

# ─── Sandbox & Execution ──────────────────────────────────────────────────────
sandbox_mode = "workspace-write"

# ─── Commit Settings ──────────────────────────────────────────────────────────
commit_attribution = ""

# ─── Permissions ─────────────────────────────────────────────────────────────
default_permissions = "dev"

[permissions.dev.filesystem]
":minimal" = "read"

[permissions.dev.network]
enabled = true
