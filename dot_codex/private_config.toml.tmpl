{{- $work := joinPath .chezmoi.homeDir ".local/share/chezmoi-private/codex_work.toml" -}}
model_reasoning_effort = "high"
suppress_unstable_features_warning = true

# ─── Approvals ───────────────────────────────────────────────────────────────
# Prompt when escalating out of the sandbox — parity with Claude Code, which
# auto-runs in-scope actions and asks for the rest. (sandbox_mode is omitted on
# purpose: default_permissions below overrides it, so it would be dead.)
approval_policy = "on-request"

# ─── Commit Settings ──────────────────────────────────────────────────────────
commit_attribution = ""

# ─── Permissions (parity with Claude Code — read all, write workspace, network on) ──
default_permissions = "dev"
{{ output "sh" "-c" `grep -m1 '^model = ' "$HOME/.codex/config.toml" 2>/dev/null || true` }}
[permissions.dev.filesystem]
":root" = "read"
":workspace_roots" = "write"

[permissions.dev.network]
enabled = true
{{ if stat $work }}{{ output "cat" $work }}{{ end -}}
{{ output "sh" "-c" `kept=$(awk '/^\[/{f=($0 ~ /^\[(tui\.model_availability_nux\]|projects\.|notice\])/)} f' "$HOME/.codex/config.toml" 2>/dev/null); test -n "$kept" && printf '\n%s\n\n' "$kept" || true` -}}
