# Public Brewfile — the baseline installed on every machine this source applies to.
# A downstream private chezmoi source (chezmoi apply --source ~/.local/share/chezmoi-private)
# may overlay it: ~/.local/share/chezmoi-private/Brewfile adds private-only entries, and
# Brewfile.skip lists public entries to drop on that machine (e.g. legcord, opencode on work).
# The brew-bundle runner merges the two and applies the skip-list. Only direct (leaf) packages
# belong here — transitive dependencies are pulled in automatically.

# Taps
tap "anomalyco/tap"

# Core tools
brew "atuin"            # shell history search
brew "bat"              # cat with syntax highlighting
brew "chezmoi"          # dotfiles manager
brew "crane"            # daemon-free container image/registry tool
brew "direnv"           # directory-specific env vars
brew "duti"             # file association manager
brew "fd"               # fast, user-friendly find
brew "fish"             # friendly interactive shell
brew "fzf"              # fuzzy finder
brew "gh"               # GitHub CLI
brew "git"              # version control
brew "git-delta"        # syntax-highlighting git diff pager
brew "git-lfs"          # git large file storage
brew "glow"             # markdown renderer
brew "gping"            # ping with graph
brew "htop"             # process viewer
brew "lsd"              # ls with icons
brew "mas"              # Mac App Store CLI
brew "mise"             # polyglot version/tool manager
brew "mprocs"           # TUI multi-process runner
brew "neovim"           # text editor
brew "parallel"         # parallel command execution
brew "prek"             # pre-commit in Rust
brew "tig"              # git TUI
brew "tmux"             # terminal multiplexer
brew "tree"             # directory tree viewer
brew "universal-ctags"  # source code tags
brew "watch"            # run command repeatedly
brew "wget"             # download tool
brew "yq"               # YAML processor
brew "zoxide"           # smarter cd

# Languages & runtimes
brew "bun"              # JavaScript runtime/bundler
brew "go"               # Go toolchain
brew "node"             # JavaScript runtime
brew "nushell"          # structured-data shell
brew "openjdk"          # Java (latest)
brew "openjdk@21"       # Java LTS
brew "powershell"       # PowerShell
brew "rustup"           # Rust toolchain manager

# GNU tools
