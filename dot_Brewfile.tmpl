brew "gawk"             # GNU awk
brew "gcc"              # GNU compiler collection
brew "gnu-indent"       # GNU indent
brew "gnu-sed"          # GNU sed
brew "make"             # GNU make
brew "zip"              # compression

# Build & document tools
brew "aria2"            # download accelerator
brew "cmake"            # build system
brew "graphviz"         # graph visualization
brew "hugo"             # static site generator
brew "hyperfine"        # benchmarking
brew "gdu"              # disk usage analyzer
brew "jq"               # JSON processor
brew "llvm"             # compiler toolchain
brew "maven"            # Java build tool
brew "meson"            # build system
brew "ncdu"             # disk usage analyzer
brew "ncurses"          # terminal library
brew "pandoc"           # document converter
brew "pinentry-mac"     # GPG pinentry for macOS
brew "pkg-config"       # compile helper
brew "poppler"          # PDF utilities
brew "ripgrep"          # fast grep
brew "shellcheck"       # shell linter
brew "shfmt"            # shell formatter
brew "sqlite"           # database
brew "sshpass"          # non-interactive ssh password
brew "texlive"          # TeX distribution
brew "tokei"            # code statistics
brew "yamlfmt"          # YAML formatter
brew "yamllint"         # YAML linter
brew "zbar"             # barcode/QR reader

# CLI services
brew "googleworkspace-cli"     # Google Workspace CLI
brew "anomalyco/tap/opencode"  # AI coding agent (private may skip)

# Applications
cask "alt-tab"                   # window switcher
cask "betterdisplay"             # display management
cask "codex"                     # OpenAI Codex CLI
cask "discord"                   # voice and text chat
cask "element"                   # Matrix client
cask "elgato-stream-deck"        # stream deck control
cask "gcloud-cli"                # Google Cloud SDK
cask "ghostty"                   # terminal emulator
cask "gifox"                     # GIF recorder
cask "google-chrome"             # web browser
cask "google-drive"              # Google Drive desktop app
cask "iina"                      # video player
cask "insta360-link-controller"  # webcam control
cask "jetbrains-toolbox"         # IDE manager
cask "launchcontrol"             # launchd manager
cask "legcord"                   # Discord client (private may skip)
cask "logi-options+"             # Logitech mouse/keyboard settings
cask "path-finder"               # file manager
cask "rode-central"              # RODE audio device control
