#!/bin/bash
# cargo packages hash: {{ include "dot_cargo_packages.txt" | sha256sum }}
set -euo pipefail

export PATH="$HOME/.cargo/bin:$PATH"

if [ -d /opt/bb/lib/pkgconfig ]; then
    export PKG_CONFIG_PATH="/opt/bb/lib64/pkgconfig:/opt/bb/lib/pkgconfig${PKG_CONFIG_PATH:+:$PKG_CONFIG_PATH}"
fi

if ! command -v cargo >/dev/null 2>&1; then
    exit 0
fi

echo "📦 Installing cargo packages..."

while IFS= read -r pkg; do
    [[ -z "$pkg" || "$pkg" =~ ^# ]] && continue
    echo "  Installing $pkg..."
    cargo install --locked "$pkg"
done < "$HOME/.cargo_packages.txt"

echo "✅ cargo packages installed"
