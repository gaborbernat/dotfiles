#!/bin/bash
# Private scripts hash: {{ glob (joinPath .chezmoi.homeDir ".local/share/chezmoi-private/scripts/src/*.py") | join "\n" | sha256sum }}
set -euo pipefail

if [[ -d "$HOME/.local/share/chezmoi-private/scripts/src" ]]; then
    echo "📦 Generating wrapper scripts for private Python scripts..."
    for script in "$HOME/.local/share/chezmoi-private/scripts/src"/*.py; do
        if [[ -f "$script" ]]; then
            name=$(basename "$script" .py)
            wrapper="$HOME/.local/bin/$name"
            cat > "$wrapper" << EOF
#!/bin/bash
set -euo pipefail
uv run -- "\$HOME/.local/share/chezmoi-private/scripts/src/$name.py" "\$@"
EOF
            chmod +x "$wrapper"
            echo "  Created wrapper: $name"
        fi
    done
    for wrapper in "$HOME/.local/bin"/*; do
        if [[ -f "$wrapper" ]] && grep -qF 'chezmoi-private/scripts/src/' "$wrapper"; then
            name=$(basename "$wrapper")
            [[ -f "$HOME/.local/share/chezmoi-private/scripts/src/$name.py" ]] || rm "$wrapper"
        fi
    done
    echo "✅ Private script wrappers generated"
fi
